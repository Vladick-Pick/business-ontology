{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/business-ontology/model-change-package.schema.json",
  "title": "Business ontology model change package",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "packageId": {
      "type": "string",
      "pattern": "^mcpkg-[a-z0-9][a-z0-9-]*$"
    },
    "moduleId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "modelPackId": {
      "type": "string",
      "pattern": "^mp-[a-z0-9][a-z0-9-]*$"
    },
    "modelPackVersion": {
      "type": "string",
      "minLength": 1
    },
    "ontologyRevision": {
      "type": "string",
      "minLength": 1
    },
    "compiler": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "mode": {
          "type": "string",
          "enum": ["synthetic-fixture", "manual-review", "automated"]
        }
      },
      "required": ["name", "version", "mode"]
    },
    "sourceEventIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^srcevt-[a-z0-9][a-z0-9-]*$"
      }
    },
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "changeId": {
            "type": "string",
            "pattern": "^chg-[a-z0-9][a-z0-9-]*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "new-object",
              "new-definition",
              "new-decision",
              "new-agreement",
              "drift",
              "conflict",
              "source-of-truth-change",
              "dashboard-metric-concern",
              "stale-area",
              "no-op",
              "system-analysis-result"
            ]
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "claimKind": {
            "type": "string",
            "enum": [
              "observed-fact",
              "owner-claim",
              "regulation",
              "dashboard-reading",
              "agent-inference",
              "human-decision",
              "unknown"
            ]
          },
          "evidenceGrade": {
            "type": "string",
            "enum": [
              "measured",
              "instance",
              "external",
              "claim",
              "inference",
              "hypothesis",
              "framing",
              "unknown"
            ]
          },
          "sourceRisk": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "allOf": [
              {
                "not": {
                  "allOf": [
                    {"contains": {"const": "unknown"}},
                    {"minItems": 2}
                  ]
                }
              },
              {
                "not": {
                  "allOf": [
                    {"contains": {"const": "no-known-risk"}},
                    {"minItems": 2}
                  ]
                }
              }
            ],
            "items": {
              "type": "string",
              "enum": [
                "no-known-risk",
                "stale-document",
                "partial-export",
                "manual-memory",
                "formula-unknown",
                "conflicting-source",
                "raw-source-unavailable",
                "owner-unknown",
                "unknown"
              ]
            }
          },
          "affectedIds": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "sourceEventId": {
                  "type": "string",
                  "pattern": "^srcevt-[a-z0-9][a-z0-9-]*$"
                },
                "locator": {"type": "string", "minLength": 1},
                "excerpt": {"type": "string", "minLength": 1, "maxLength": 280}
              },
              "required": ["sourceEventId", "locator", "excerpt"]
            }
          },
          "proposedAction": {
            "type": "string",
            "enum": [
              "prepare-staged-proposal",
              "open-drift-review",
              "open-conflict-review",
              "review-source-of-truth",
              "review-dashboard-metric",
              "review-system-analysis-result",
              "needs-info",
              "record-no-op"
            ]
          },
          "systemAnalysisResultId": {
            "type": "string",
            "pattern": "^sysres-[a-z0-9][a-z0-9-]*$"
          },
          "systemAnalysisClassification": {
            "type": "string",
            "enum": [
              "recommendation-only",
              "experiment",
              "model-change-candidate",
              "drift-item",
              "decision-candidate",
              "no-op"
            ]
          },
          "candidateCard": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]*$"
              },
              "type": {
                "type": "string",
                "enum": [
                  "concept",
                  "module",
                  "production-system",
                  "interface",
                  "process",
                  "state",
                  "decision"
                ]
              },
              "status": {
                "type": "string",
                "enum": ["candidate", "hypothesis", "conflict", "unknown", "proposed"]
              },
              "source": {"type": "string", "minLength": 1},
              "owner": {"type": "string", "minLength": 1},
              "links": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "produces": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
                  },
                  "consumes": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
                  },
                  "supplies-to": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
                  },
                  "part-of": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
                  },
                  "owns": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
                  },
                  "measured-by": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
                  },
                  "source-of-truth": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
                  },
                  "in-state": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
                  },
                  "governed-by": {
                    "type": "array",
                    "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"}
                  }
                }
              },
              "summary": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1000
              },
              "attrs": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "required": ["id", "type", "status", "source", "owner", "summary"],
            "allOf": [
              {
                "if": {
                  "properties": {
                    "type": {"const": "decision"}
                  },
                  "required": ["type"]
                },
                "then": {
                  "required": ["attrs"],
                  "properties": {
                    "status": {"enum": ["proposed"]},
                    "attrs": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "irreversible": {"type": "boolean"},
                        "episode": {"type": "string", "minLength": 1},
                        "scope": {"type": "string", "minLength": 1},
                        "decision-owner": {"type": "string", "minLength": 1},
                        "transition-authority": {"type": "string", "minLength": 1},
                        "measurement-convention": {"type": "string", "minLength": 1},
                        "affected-workflows": {
                          "anyOf": [
                            {"type": "string", "minLength": 1},
                            {
                              "type": "array",
                              "minItems": 1,
                              "items": {"type": "string", "minLength": 1}
                            }
                          ]
                        },
                        "affected-kpis": {
                          "anyOf": [
                            {"type": "string", "minLength": 1},
                            {
                              "type": "array",
                              "minItems": 1,
                              "items": {"type": "string", "minLength": 1}
                            }
                          ]
                        },
                        "propagation-sla": {"type": "string", "minLength": 1},
                        "override-policy": {"type": "string", "minLength": 1},
                        "exception-path": {"type": "string", "minLength": 1},
                        "blast-radius": {"type": "string", "minLength": 1}
                      },
                      "required": [
                        "irreversible",
                        "episode",
                        "scope",
                        "decision-owner",
                        "transition-authority",
                        "measurement-convention",
                        "affected-workflows",
                        "affected-kpis",
                        "propagation-sla",
                        "override-policy",
                        "exception-path",
                        "blast-radius"
                      ]
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "type": {
                      "enum": [
                        "concept",
                        "module",
                        "production-system",
                        "interface",
                        "process",
                        "state"
                      ]
                    }
                  },
                  "required": ["type"]
                },
                "then": {
                  "properties": {
                    "status": {"enum": ["candidate", "hypothesis", "conflict", "unknown"]}
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "type": {"const": "interface"}
                  },
                  "required": ["type"]
                },
                "then": {
                  "required": ["attrs"],
                  "properties": {
                    "attrs": {
                      "type": "object",
                      "additionalProperties": false,
                      "properties": {
                        "participants": {
                          "type": "object",
                          "additionalProperties": false,
                          "properties": {
                            "supplier": {
                              "type": "array",
                              "minItems": 1,
                              "items": {
                                "type": "string",
                                "pattern": "^[a-z0-9][a-z0-9-]*$"
                              }
                            },
                            "customer": {
                              "type": "array",
                              "minItems": 1,
                              "items": {
                                "type": "string",
                                "pattern": "^[a-z0-9][a-z0-9-]*$"
                              }
                            },
                            "subject": {
                              "type": "array",
                              "minItems": 1,
                              "items": {
                                "type": "string",
                                "pattern": "^[a-z0-9][a-z0-9-]*$"
                              }
                            }
                          },
                          "required": ["supplier", "customer", "subject"]
                        },
                        "quality-criterion": {"type": "string", "minLength": 1},
                        "outcome": {"type": "string", "minLength": 1}
                      },
                      "required": ["participants", "quality-criterion", "outcome"]
                    }
                  }
                }
              }
            ]
          },
          "drift": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "was": {"type": "string"},
              "now": {"type": "string"},
              "reason": {"type": "string"}
            },
            "required": ["was", "now", "reason"]
          },
          "acceptedItem": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "item": {
                "$ref": "canonical-model-store.schema.json#/$defs/acceptedItem"
              },
              "definitions": {
                "type": "array",
                "items": {
                  "$ref": "canonical-model-store.schema.json#/$defs/definition"
                }
              },
              "attributes": {
                "type": "array",
                "items": {
                  "$ref": "canonical-model-store.schema.json#/$defs/attribute"
                }
              },
              "criteria": {
                "type": "array",
                "items": {
                  "$ref": "canonical-model-store.schema.json#/$defs/criterion"
                }
              },
              "examples": {
                "type": "array",
                "items": {
                  "$ref": "canonical-model-store.schema.json#/$defs/example"
                }
              }
            },
            "required": ["item"]
            },
            "acceptedWorkflow": {
              "type": "object",
              "additionalProperties": false,
            "properties": {
              "workflow": {
                "$ref": "canonical-model-store.schema.json#/$defs/workflow"
              },
              "participants": {
                "type": "array",
                "items": {
                  "$ref": "canonical-model-store.schema.json#/$defs/workflowParticipant"
                }
              },
              "steps": {
                "type": "array",
                "items": {
                  "$ref": "canonical-model-store.schema.json#/$defs/workflowStep"
                }
              },
              "transitions": {
                "type": "array",
                "items": {
                  "$ref": "canonical-model-store.schema.json#/$defs/workflowTransition"
                }
              },
              "exceptions": {
                "type": "array",
                "items": {
                  "$ref": "canonical-model-store.schema.json#/$defs/workflowException"
                }
              },
              "metrics": {
                "type": "array",
                "items": {
                  "$ref": "canonical-model-store.schema.json#/$defs/workflowMetric"
                }
              }
            },
            "required": ["workflow"]
          }
        },
        "allOf": [
          {
            "if": {"required": ["systemAnalysisResultId"]},
            "then": {"required": ["systemAnalysisClassification"]}
          },
          {
            "if": {"required": ["systemAnalysisClassification"]},
            "then": {"required": ["systemAnalysisResultId"]}
          },
          {
            "if": {
              "properties": {
                "claimKind": {"const": "agent-inference"}
              },
              "required": ["claimKind"]
            },
            "then": {
              "properties": {
                "evidenceGrade": {"enum": ["inference", "hypothesis"]}
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {"const": "system-analysis-result"}
              },
              "required": ["kind"]
            },
            "then": {
              "required": ["systemAnalysisResultId", "systemAnalysisClassification"]
            }
          },
          {
            "if": {
              "properties": {
                "proposedAction": {"const": "review-system-analysis-result"}
              },
              "required": ["proposedAction"]
            },
            "then": {
              "required": ["systemAnalysisResultId", "systemAnalysisClassification"]
            }
          }
        ],
        "required": [
          "changeId",
          "kind",
          "confidence",
          "risk",
          "claimKind",
          "evidenceGrade",
          "sourceRisk",
          "affectedIds",
          "evidence",
          "proposedAction"
        ]
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "overallAction": {
          "type": "string",
          "enum": ["human-review", "needs-owner", "no-review-needed"]
        },
        "owner": {"type": "string", "minLength": 1},
        "reason": {"type": "string", "minLength": 1}
      },
      "required": ["overallAction", "owner", "reason"]
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "noPii": {"type": "boolean", "const": true},
        "noSecrets": {"type": "boolean", "const": true},
        "noRawPayload": {"type": "boolean", "const": true},
        "noAcceptedMutation": {"type": "boolean", "const": true}
      },
      "required": ["noPii", "noSecrets", "noRawPayload", "noAcceptedMutation"]
    }
  },
  "required": [
    "packageId",
    "moduleId",
    "modelPackId",
    "modelPackVersion",
    "ontologyRevision",
    "compiler",
    "sourceEventIds",
    "generatedAt",
    "summary",
    "changes",
    "review",
    "safety"
  ]
}
