{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/business-ontology/human-request.schema.json",
  "title": "Business ontology human request",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "requestId": {
      "type": "string",
      "pattern": "^hreq-[a-z0-9][a-z0-9-]*$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "review",
        "clarification",
        "setup",
        "live-proof",
        "migration",
        "source-access"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["open", "answered", "deferred", "superseded", "cancelled"]
    },
    "owner": {"type": "string", "minLength": 1},
    "channel": {"type": "string", "minLength": 1},
    "messageRef": {"type": "string"},
    "prompt": {"type": "string", "minLength": 1, "maxLength": 1000},
    "recommendedAnswer": {"type": "string", "minLength": 1, "maxLength": 1000},
    "blocks": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "sourceRef": {"type": "string"},
    "packageId": {"type": "string"},
    "askedAt": {"type": "string", "minLength": 1},
    "dueAt": {"type": "string"},
    "answeredAt": {"type": "string"},
    "answerSummary": {"type": "string", "maxLength": 1000},
    "decisionId": {"type": "string"}
  },
  "required": [
    "requestId",
    "kind",
    "status",
    "owner",
    "channel",
    "messageRef",
    "prompt",
    "recommendedAnswer",
    "blocks",
    "sourceRef",
    "packageId",
    "askedAt",
    "dueAt",
    "answeredAt",
    "answerSummary",
    "decisionId"
  ]
}
