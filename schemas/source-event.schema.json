{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/business-ontology/source-event.schema.json",
  "title": "Business ontology source event",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "pattern": "^srcevt-[a-z0-9][a-z0-9-]*$"
    },
    "sourceId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "sourceKind": {
      "type": "string",
      "enum": [
        "human-session",
        "telegram-export",
        "meeting-transcript",
        "dashboard-snapshot",
        "crm-export",
        "document",
        "manual-drop",
        "google-drive",
        "calendar-event"
      ]
    },
    "observedAt": {
      "type": "string",
      "minLength": 1
    },
    "connector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "mode": {
          "type": "string",
          "enum": ["manual-export", "api-read", "file-drop"]
        },
        "readOnly": {"type": "boolean", "const": true}
      },
      "required": ["name", "version", "mode", "readOnly"]
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "owner": {"type": "string", "minLength": 1},
        "accessMode": {"type": "string", "minLength": 1},
        "registered": {"type": "boolean"}
      },
      "required": ["owner", "accessMode", "registered"]
    },
    "trustFloor": {
      "type": "string",
      "enum": ["candidate", "hypothesis", "conflict", "deprecated", "unknown"]
    },
    "claimKind": {
      "type": "string",
      "enum": [
        "observed-fact",
        "owner-claim",
        "regulation",
        "dashboard-reading",
        "agent-inference",
        "human-decision",
        "unknown"
      ]
    },
    "evidenceGrade": {
      "type": "string",
      "enum": [
        "measured",
        "instance",
        "external",
        "claim",
        "inference",
        "hypothesis",
        "framing",
        "unknown"
      ]
    },
    "sourceRisk": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "allOf": [
        {
          "not": {
            "allOf": [
              {"contains": {"const": "unknown"}},
              {"minItems": 2}
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {"contains": {"const": "no-known-risk"}},
              {"minItems": 2}
            ]
          }
        }
      ],
      "items": {
        "type": "string",
        "enum": [
          "no-known-risk",
          "stale-document",
          "partial-export",
          "manual-memory",
          "formula-unknown",
          "conflicting-source",
          "raw-source-unavailable",
          "owner-unknown",
          "auto-transcription-risk",
          "speaker-attribution-uncertain",
          "meeting-scope-unconfirmed",
          "provider-transcript-unverified",
          "unknown"
        ]
      }
    },
    "provenanceActivity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activityType": {
          "type": "string",
          "enum": [
            "manual-export",
            "api-read",
            "file-drop",
            "agent-extraction",
            "human-confirmation",
            "dashboard-read",
            "document-read",
            "unknown"
          ]
        },
        "actor": {"type": "string", "minLength": 1},
        "actorType": {
          "type": "string",
          "enum": ["human", "agent", "connector", "system", "unknown"]
        },
        "createdAt": {"type": "string", "minLength": 1},
        "sourceLocator": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 1}
      },
      "required": [
        "activityType",
        "actor",
        "actorType",
        "createdAt",
        "sourceLocator",
        "method"
      ]
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "piiExcluded": {"type": "boolean", "const": true},
        "rawPayloadIncluded": {"type": "boolean", "const": false},
        "redactionNotes": {"type": "string"}
      },
      "required": ["piiExcluded", "rawPayloadIncluded"]
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "locator": {"type": "string", "minLength": 1},
          "segmentType": {
            "type": "string",
            "enum": ["time-range", "line-range", "cell-range", "record-class", "section", "widget"]
          },
          "start": {"type": "string"},
          "end": {"type": "string"},
          "excerpt": {"type": "string", "minLength": 1, "maxLength": 280},
          "notes": {"type": "string"}
        },
        "required": ["locator", "segmentType", "excerpt"]
      }
    },
    "contentSummary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "claimKind": {"const": "agent-inference"}
        },
        "required": ["claimKind"]
      },
      "then": {
        "properties": {
          "evidenceGrade": {"enum": ["inference", "hypothesis"]}
        }
      }
    }
  ],
  "required": [
    "eventId",
    "sourceId",
    "sourceKind",
    "observedAt",
    "connector",
    "authority",
    "trustFloor",
    "claimKind",
    "evidenceGrade",
    "sourceRisk",
    "provenanceActivity",
    "redaction",
    "evidence",
    "contentSummary",
    "hash"
  ]
}
