{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/business-ontology/card.schema.json",
  "title": "Business ontology card frontmatter",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "type": {
      "type": "string",
      "description": "Data model v2 (see docs/specs/2026-07-02-data-model-v2.md): 11 closed authoring types. Legacy `module` and `concept` are accepted only by the migration validator path, not by this schema.",
      "enum": [
        "business",
        "production-system",
        "role",
        "artifact",
        "tool",
        "metric",
        "state",
        "process",
        "interface",
        "decision",
        "term"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "accepted",
        "candidate",
        "hypothesis",
        "conflict",
        "deprecated",
        "unknown",
        "proposed",
        "implemented",
        "superseded",
        "retired"
      ]
    },
    "source": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "produces": {
          "type": "array",
          "items": {"type": "string"}
        },
        "consumes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "supplies-to": {
          "type": "array",
          "items": {"type": "string"}
        },
        "part-of": {
          "type": "array",
          "items": {"type": "string"}
        },
        "owns": {
          "type": "array",
          "items": {"type": "string"}
        },
        "measured-by": {
          "type": "array",
          "items": {"type": "string"}
        },
        "source-of-truth": {
          "type": "array",
          "items": {"type": "string"}
        },
        "lifecycle": {
          "type": "array",
          "items": {"type": "string"}
        },
        "influences": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Target ids this card influences. Polarity/delay ride in the parallel attrs.influences block (see docs/specs/2026-07-02-data-model-v2.md and references/ai-ready.md)."
        },
        "governed-by": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "last-reviewed": {
      "type": "string"
    },
    "next-audit": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence": {
      "type": "array",
      "items": {"type": "string"}
    },
    "volatility": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "attrs": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "id",
    "type",
    "status",
    "source",
    "owner",
    "last-reviewed",
    "next-audit"
  ]
}
