{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/business-ontology/model-pack.schema.json",
  "title": "Business ontology model pack",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "modelPackId": {
      "type": "string",
      "pattern": "^mp-[a-z0-9][a-z0-9-]*$"
    },
    "moduleId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "owners": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary": {"type": "string", "minLength": 1},
        "review": {"type": "string", "minLength": 1},
        "escalation": {"type": "string", "minLength": 1}
      },
      "required": ["primary", "review", "escalation"]
    },
    "objectTypes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {"type": "string", "minLength": 1},
          "cardTypes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "business",
                "production-system",
                "role",
                "artifact",
                "tool",
                "metric",
                "state",
                "process",
                "interface",
                "decision",
                "term",
                "module",
                "concept"
              ]
            }
          },
          "description": {"type": "string", "minLength": 1}
        },
        "required": ["id", "name", "cardTypes", "description"]
      }
    },
    "relationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowedRelations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "produces",
              "consumes",
              "supplies-to",
              "part-of",
              "owns",
              "measured-by",
              "source-of-truth",
              "in-state",
              "lifecycle",
              "influences",
              "governed-by"
            ]
          }
        },
        "sourceOfTruthRules": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      },
      "required": ["allowedRelations"]
    },
    "sourceAuthority": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "sourceKind": {"type": "string", "minLength": 1},
          "maxStatus": {
            "type": "string",
            "enum": [
              "accepted",
              "candidate",
              "hypothesis",
              "conflict",
              "deprecated",
              "unknown"
            ]
          },
          "reviewRequired": {"type": "boolean"},
          "description": {"type": "string", "minLength": 1}
        },
        "required": ["sourceKind", "maxStatus", "reviewRequired", "description"]
      }
    },
    "highRiskFields": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "reviewOwners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "scope": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "appliesTo": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "highRiskOnly": {"type": "boolean"}
        },
        "required": ["scope", "owner", "appliesTo", "highRiskOnly"]
      }
    },
    "digestPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cadence": {
          "type": "string",
          "enum": ["daily", "weekly", "manual"]
        },
        "minimumQuietHours": {
          "type": "integer",
          "minimum": 0
        },
        "changeThreshold": {
          "type": "integer",
          "minimum": 0
        },
        "reportChannels": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "required": ["cadence", "minimumQuietHours", "changeThreshold", "reportChannels"]
    },
    "competencyQuestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "questionId": {
            "type": "string",
            "pattern": "^cq-[a-z0-9][a-z0-9-]*$"
          },
          "scopeId": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "question": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "decisionUse": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "answerStatus": {
            "type": "string",
            "enum": ["answered", "partially-answered", "unanswered", "blocked"]
          },
          "answeredByIds": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            }
          },
          "missingFields": {
            "type": "array",
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          },
          "owner": {"type": "string", "minLength": 1},
          "lastReviewedAt": {"type": "string", "minLength": 1}
        },
        "required": [
          "questionId",
          "scopeId",
          "question",
          "decisionUse",
          "answerStatus",
          "answeredByIds",
          "missingFields",
          "owner",
          "lastReviewedAt"
        ]
      }
    },
    "businessArchitecture": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "valueStreams": {
          "type": "array",
          "items": {"$ref": "#/$defs/businessArchitectureNode"}
        },
        "valueStages": {
          "type": "array",
          "items": {"$ref": "#/$defs/businessArchitectureNode"}
        },
        "capabilities": {
          "type": "array",
          "items": {"$ref": "#/$defs/businessArchitectureNode"}
        },
        "stakeholders": {
          "type": "array",
          "items": {"$ref": "#/$defs/businessArchitectureNode"}
        },
        "valueItems": {
          "type": "array",
          "items": {"$ref": "#/$defs/businessArchitectureNode"}
        },
        "businessObjects": {
          "type": "array",
          "items": {"$ref": "#/$defs/businessArchitectureNode"}
        },
        "relations": {
          "type": "array",
          "items": {"$ref": "#/$defs/businessArchitectureRelation"}
        }
      },
      "required": [
        "valueStreams",
        "valueStages",
        "capabilities",
        "stakeholders",
        "valueItems",
        "businessObjects",
        "relations"
      ]
    },
    "compilerHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "preferredObjectTypes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "extractionPriorities": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "ignorePatterns": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "maxEvidenceItems": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "preferredObjectTypes",
        "extractionPriorities",
        "ignorePatterns",
        "maxEvidenceItems"
      ]
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "businessArchitectureNode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1}
      },
      "required": ["id", "name", "description"]
    },
    "businessArchitectureRelation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relation": {
          "type": "string",
          "enum": [
            "stakeholder-triggers-value-stream",
            "value-stream-contains-value-stage",
            "capability-enables-value-stage",
            "value-stage-delivers-value-item",
            "workflow-realizes-value-stage",
            "business-object-changes-state-in-workflow"
          ]
        },
        "fromId": {"$ref": "#/$defs/id"},
        "toId": {"$ref": "#/$defs/id"}
      },
      "required": ["relation", "fromId", "toId"]
    }
  },
  "required": [
    "modelPackId",
    "moduleId",
    "version",
    "owners",
    "objectTypes",
    "relationPolicy",
    "sourceAuthority",
    "highRiskFields",
    "reviewOwners",
    "digestPolicy",
    "competencyQuestions",
    "businessArchitecture",
    "compilerHints"
  ]
}
