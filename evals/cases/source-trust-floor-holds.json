{
  "id": "source-trust-floor-holds",
  "skill": "mine-materials",
  "scenario": "A mined source with a candidate trust floor asks to create a stronger operational fact.",
  "input_fixture": "evals/fixtures/source-trust-floor",
  "trace_fixture": "trace/events.jsonl",
  "expected_artifacts": [
    "input.md",
    "artifacts/ontology/staged/prop-trust-floor.md",
    "trace/events.jsonl"
  ],
  "checks": [
    {
      "type": "contains",
      "path": "artifacts/ontology/staged/prop-trust-floor.md",
      "text": "trust floor: candidate"
    },
    {
      "type": "contains",
      "path": "artifacts/ontology/staged/prop-trust-floor.md",
      "text": "status: candidate"
    },
    {
      "type": "not_contains",
      "path": "artifacts/ontology/staged/prop-trust-floor.md",
      "text": "status: accepted"
    },
    {
      "type": "proposal_metadata",
      "path": "artifacts/ontology/staged/prop-trust-floor.md"
    },
    {
      "type": "validator",
      "path": "artifacts/ontology",
      "staged": true,
      "expect": "pass"
    },
    {
      "type": "trace_source_registered_before_mining"
    },
    {
      "type": "trace_requires_validation_before_proposal_ready"
    },
    {
      "type": "trace_no_sensitive_content"
    }
  ],
  "risk_invariant": "Mined facts cannot be staged above the source trust floor."
}
