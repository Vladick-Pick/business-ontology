      "path": "reviews/rev-mcp-boundary-001.json",
      "status": "pending",
      "owner": "role:systems-owner",
      "requiredAction": "review-source-of-truth",
      "forbiddenAction": "prepare-staged-proposal"
    },
    {
      "type": "contains",
      "path": "resources/pending-review-packages.json",
      "text": "ontology://acquisition/review/packages"
    },
    {
      "type": "not_contains",
      "path": "resources/pending-review-packages.json",
      "text": "gbrain://"
    },
    {
      "type": "contains",
      "path": "accepted-before/ontology-snapshot.json",
      "text": "canonical model store plus human decision log and validation"
    },
    {
      "type": "contains",
